# Secretos del STACK DOCKER (docker compose). Copia a .env y pon valores reales.
# En desarrollo local (nodemon + vite) NO se usa este archivo; usa backend/.env.

# Puerto del host donde escucha el frontend (nginx). Def. 80 (produccion).
# En local, si el 80 esta ocupado, usa p.ej. 8080.
FRONTEND_PORT=80

# Contraseña del usuario 'app' de MySQL
DB_PASSWORD=

# Contraseña root de MySQL
DB_ROOT_PASSWORD=

# Secreto para firmar JWT (Sprint 1+)
JWT_SECRET=

# Caducidad del token (opcional, def. 8h)
JWT_EXPIRES=8h

# IA (Claude) — necesario para matching y parsing de CV
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Sincronización del esquema al arrancar el backend:
#   alter (def.) -> ajusta las tablas a los modelos (crea las que falten)
#   force        -> DROP + CREATE (¡BORRA DATOS! solo para reset)
#   none         -> no sincroniza (usar migraciones sequelize-cli a mano)
DB_SYNC=alter

# Admin inicial que se crea/actualiza al arrancar (idempotente).
# Con esto puedes hacer login la primera vez. Cambia la contraseña tras entrar.
ADMIN_NOMBRE=Administrador
ADMIN_EMAIL=
ADMIN_PASSWORD=
