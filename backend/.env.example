# Backend en DESARROLLO (nodemon, MySQL local). Copia a backend/.env y pon tus valores reales.
NODE_ENV=development
PORT=4000

# MySQL local
DB_HOST=localhost
DB_PORT=3306
DB_NAME=thehuntertech
DB_USER=root
DB_PASSWORD=misistema

# JWT
JWT_SECRET=
JWT_EXPIRES=8h

# Seed del admin inicial (npm run seed:admin) — pon la contraseña en backend/.env, no aquí
ADMIN_NOMBRE=Administrador
ADMIN_EMAIL=admin@thehunter.tech
ADMIN_PASSWORD=
